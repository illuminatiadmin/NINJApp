<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:weightSum="10"
    android:background="#0a0a0f">

    <!-- Terminal Panel (Left) -->
    <LinearLayout
        android:id="@+id/terminal_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5"
        android:orientation="vertical"
        android:background="#0d0d14"
        android:padding="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:text=">_ TERMINAL"
            android:textColor="#00ff41"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#111118" />

        <ScrollView
            android:id="@+id/terminal_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0d0d14"
            android:fillViewport="true">

            <TextView
                android:id="@+id/terminal_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textColor="#00ff41"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:background="#0d0d14" />

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#111118"
            android:padding="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="$ "
                android:textColor="#00ff41"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingLeft="6dp" />

            <EditText
                android:id="@+id/terminal_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:textColor="#e0e0e0"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:inputType="text" />

            <Button
                android:id="@+id/terminal_send"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="▶"
                android:textColor="#00ff41"
                android:textSize="11sp"
                android:background="#1a1a2a"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:fontFamily="monospace"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Draggable Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:background="#00ff41"
        android:alpha="0.3" />

    <!-- Guide Panel (Right) -->
    <LinearLayout
        android:id="@+id/guide_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5"
        android:orientation="vertical"
        android:background="#0a0a0f">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:text="📖 ASISTENTE NINJApp"
            android:textColor="#00d4ff"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#111118" />

        <WebView
            android:id="@+id/guide_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0a0a0f" />

    </LinearLayout>

</LinearLayout>
